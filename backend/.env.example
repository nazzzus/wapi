# ── Core ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-string

# Database (leave as-is for SQLite; replace with PostgreSQL URL for Railway addon)
DATABASE_URL=sqlite:////data/wapi.db

# ── Admin auth ─────────────────────────────────────────────────────────────
# Option A — Simple password (no Auth0)
ADMIN_PASSWORD=choose-a-strong-password

# Option B — Auth0 (replaces ADMIN_PASSWORD; set all 4 vars below)
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
# AUTH0_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AUTH0_CALLBACK_URL=https://your-railway-url.up.railway.app/admin/callback
# Comma-separated list of emails allowed to access the admin panel
# ADMIN_EMAIL_WHITELIST=nazir@sultani.de

# ── Lemon Squeezy ─────────────────────────────────────────────────────────
LS_API_KEY=your-lemon-squeezy-api-key
LS_WEBHOOK_SECRET=your-webhook-signing-secret
LS_STORE_ID=your-store-id

# ── Environment ────────────────────────────────────────────────────────────
# Set to "development" locally to disable HTTPS-only cookies
# FLASK_ENV=development
